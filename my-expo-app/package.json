{
  "name": "my-expo-app",
  "version": "1.0.1",
  "scripts": {
    "android": "node node_modules/expo/bin/cli start --android",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "start": "node node_modules/expo/bin/cli start",
    "prebuild": "node node_modules/expo/bin/cli prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "node node_modules/expo/bin/cli start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/drawer": "^7.8.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@react-navigation/stack": "^7.7.1",
    "axios": "^1.7.2",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.11",
    "lightningcss": "^1.32.0",
    "nativewind": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "optionalDependencies": {
    "lightningcss-win32-x64-msvc": "^1.32.0"
  },
  "overrides": {
    "lightningcss": "$lightningcss",
    "react-native-css-interop": {
      "lightningcss": "$lightningcss"
    }
  }
}
